{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "types": [
            "node",
            "@playwright/test"
        ],
        "moduleResolution": "node",
        "strict": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true
    },
    "include": [
        "tests/**/*",
        "playwright.config.ts",
        "types.d.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}